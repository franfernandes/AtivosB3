DJANGO_SECRET_KEY=replace-with-a-unique-development-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Optional: without a token the demo uses PETR4, MGLU3, VALE3 and ITUB4.
# Configure a brapi token locally to list additional stocks.
BRAPI_API_KEY=

# By default email alerts are printed in the terminal during development.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@b3monitor.local

# For real SMTP sending, configure these values locally and never commit them.
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=
